# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Email (SMTP)
SMTP_EMAIL=your_email@example.com
SMTP_APP_PASSWORD=your_app_password

# External APIs
TAVILY_API_KEY=your_tavily_api_key

# OpenAI (automatically picked up by langchain-openai)
OPENAI_API_KEY=your_openai_api_key

# Glama MCP (optional — enables Google Calendar event creation for legislative dates)
# Get your API key from https://glama.ai after connecting your Google Calendar
GLAMA_API_KEY=your_glama_api_key